<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    SizeToContent="Height"
    FontSize="40"
    Topmost="True">
    <Grid Margin="10,40,10,10">
        <Grid.Resources>
            <Style TargetType="TextBlock">
                <Setter Property="FontFamily" Value="CaskaydiaCove Nerd Font Mono" />
                <Setter Property="TextBlock.Effect">
                    <Setter.Value>
                        <DropShadowEffect Direction="-45" Color="#FFB6C2CB" ShadowDepth="10" BlurRadius="14" />
                    </Setter.Value>
                </Setter>
            </Style>
        </Grid.Resources>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Column="1" Margin="10" TextAlignment="Center" FontSize="50">
            Plan for today...
        </TextBlock>
        <Image Grid.Column="1" Source="Media/PSConfEU-Logo.png" HorizontalAlignment="Right" Height="100"/>
        <Image Grid.Column="0" Grid.RowSpan="3" Source="Media/Gem.png" >
             <Image.Effect>
                <DropShadowEffect Direction="-45" Color="#FFB6C2CB" ShadowDepth="10" BlurRadius="14" />
            </Image.Effect>
        </Image>
        <StackPanel Grid.Column="1" Grid.Row="1" VerticalAlignment="Center" Margin="20,20,20,20">
            <StackPanel.Resources>
                <Style TargetType="TextBlock">
                    <Setter Property="FontSize" Value="35" />
                    <Setter Property="VerticalAlignment" Value="Center" />
                    <Setter Property="FontFamily" Value="CaskaydiaCove Nerd Font Mono" />
                    <Setter Property="TextBlock.Effect">
                        <Setter.Value>
                            <DropShadowEffect Direction="-45" Color="#FFB6C2CB" ShadowDepth="10" BlurRadius="14" />
                        </Setter.Value>
                    </Setter>
                </Style>
                <Style TargetType="Image">
                    <Setter Property="Source" Value="Media/gems-small.png" />
                    <Setter Property="RenderOptions.BitmapScalingMode" Value="Fant" />
                    <Setter Property="Stretch" Value="Fill" />
                    <Setter Property="Width" Value="120" />
                    <Setter Property="VerticalAlignment" Value="Center" />
                    <Setter Property="Margin" Value="20,20,20,20" />
                    <Setter Property="Image.Effect">
                        <Setter.Value>
                            <DropShadowEffect Direction="-45" Color="#FFB6C2CB" ShadowDepth="10" BlurRadius="14" />
                        </Setter.Value>
                    </Setter>
                </Style>
            </StackPanel.Resources>
            <StackPanel Orientation="Horizontal">
                <Image/><TextBlock>Idea</TextBlock>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Image /><TextBlock>Gems: listed</TextBlock>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Image /><TextBlock>Suggestions?</TextBlock>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Image /><TextBlock>Q&amp;A</TextBlock>
            </StackPanel>
        </StackPanel>
        <TextBlock Grid.Column="1" Grid.Row="2" FontSize="30" TextAlignment="Left" Margin="30,30,30,30">
            Forgotten Gems of PowerShell
        </TextBlock>
        <Image Grid.Column="1" Grid.Row="2" Source="Media/Wiesbaden26.png" HorizontalAlignment="Right" Height="100" />
    </Grid>
</Window>