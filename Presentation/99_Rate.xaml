<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    SizeToContent="Height"
    Topmost="True">
    <Grid Margin="10,40,10,10">
        <Grid.Resources>
            <Style TargetType="TextBlock">
                <Setter Property="TextAlignment" Value="Center" />
                <Setter Property="FontFamily" Value="CaskaydiaCove Nerd Font Mono" />
                <Setter Property="TextBlock.Effect">
                    <Setter.Value>
                        <DropShadowEffect Direction="-45" Color="#FFB6C2CB" ShadowDepth="10" BlurRadius="14" />
                    </Setter.Value>
                </Setter>
            </Style>
        </Grid.Resources>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.ColumnSpan="3" >
            <TextBlock FontSize="150">Feedback?</TextBlock>
        </Border>
        <Image Grid.Row="1" Grid.ColumnSpan="3" Source="Media/qr-code.png"/>
        <Image Grid.Row="2" Source="Media/PSConfEU-Logo.png" HorizontalAlignment="Left" Height="100"/>
        <Border Grid.Column="1" Grid.Row="2" Height="50">
            <TextBlock FontSize="30">Forgotten Gems of PowerShell</TextBlock>
        </Border>
        <Image Grid.Column="2" Grid.Row="2" Source="Media/Wiesbaden26.png" HorizontalAlignment="Right" Height="100" />
    </Grid>
</Window>
